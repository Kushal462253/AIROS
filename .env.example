# ─────────────────────────────────────────────
# AIROS — Environment Variables
# Copy this file to .env and configure local values
# ─────────────────────────────────────────────

# Backend Endpoint (e.g. uvicorn runner port)
BACKEND_URL=http://localhost:8000

# Supabase Credentials (if SQLAlchemy Supabase mappings are used)
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key

# LLM Providers API Keys (never commit real credentials)
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
GOOGLE_API_KEY=your-google-api-key

# Vector Database Storage Path
CHROMA_DB_PATH=./data/chromadb
CHROMADB_PATH=./data/chromadb

# Application Security
JWT_SECRET=your-jwt-secret-key

# Frontend Client Public Variables (prefixed with NEXT_PUBLIC_ for client runtime visibility)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
